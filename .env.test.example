# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (PostgreSQL - Test)
# -----------------------------------------------------------------------------
# Uses the db-test service from docker-compose.yml (port 5433)
# Change values if using a different local test database setup
DATABASE_URL="postgresql://pratic_enem:pratic_enem_password@localhost:5433/pratic_enem_test_db?schema=public"

# Direct connection (used by Prisma CLI in test setup)
DIRECT_URL="postgresql://pratic_enem:pratic_enem_password@localhost:5433/pratic_enem_test_db?schema=public"

# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
# Test secret - NOT for production use
# For development: use any string for testing purposes
JWT_SECRET=test_secret_key_change_in_production

# -----------------------------------------------------------------------------
# API & PUBLIC VARIABLES
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# -----------------------------------------------------------------------------
# NODE ENVIRONMENT
# -----------------------------------------------------------------------------
NODE_ENV=test