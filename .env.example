# ==========================================================
# DOCKER INFRASTRUCTURE (Local Development)
# Used by docker-compose.yml to spin up the database container
# ==========================================================
POSTGRES_USER=postgres_db_user
POSTGRES_PASSWORD=postgres_db_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=my_app_postgres_db

# ==========================================================
# APPLICATION VARIABLES (Consumed by the App)
# ==========================================================

# Database Connection
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public

# Authentication
# A long, random string used to sign JWT tokens
JWT_SECRET=your_super_secret_random_string_here

# API & Networking
# Base URL for frontend API calls (Prefixed with NEXT_PUBLIC_ for Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3000/api
