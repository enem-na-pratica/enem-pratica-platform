# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (PostgreSQL)
# -----------------------------------------------------------------------------
# Docker default values are provided. Change them if using a local installation.
POSTGRES_DB=pratic_enem_db
POSTGRES_USER=pratic_enem
POSTGRES_PASSWORD=             # Required: Set a password for your local DB
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Prisma Connection String
# Replace [PASSWORD] with your POSTGRES_PASSWORD
DATABASE_URL="postgresql://pratic_enem:[PASSWORD]@localhost:5432/pratic_enem_db?schema=public"
# Direct connection (used by Prisma CLI)
DIRECT_URL="postgresql://pratic_enem:[PASSWORD]@localhost:5432/pratic_enem_db?schema=public"

# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
# Generate a secret using: openssl rand -base64 32
JWT_SECRET=                     # Required: Unique secret for token signing

# -----------------------------------------------------------------------------
# API & PUBLIC VARIABLES
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:3000/api"