generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  name         String
  username     String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mentorshipAsStudent  StudentTeacher[] @relation("StudentRelation")
  mentorshipsAsTeacher StudentTeacher[] @relation("TeacherRelation")

  essays    Essay[]
  mockExams MockExam[]

  @@index([username])
  @@map("users") // Garante que o nome da tabela no BD seja 'users' (plural snake_case)
}

model StudentTeacher {
  id String @id @default(uuid())

  studentId String
  student   User   @relation("StudentRelation", fields: [studentId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   User   @relation("TeacherRelation", fields: [teacherId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@unique([studentId, teacherId])
  @@map("student_teachers") // Nome da tabela no banco (snake_case)
}

model Essay {
  id String @id @default(uuid())

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  theme String

  competency1 Int
  competency2 Int
  competency3 Int
  competency4 Int
  competency5 Int

  createdAt DateTime @default(now())

  @@map("essays") // Nome da tabela no banco (snake_case)
}

model Subject {
  id        String   @id @default(uuid())
  name      String   @unique
  category  String?
  topics    Topic[]
  createdAt DateTime @default(now())

  @@map("subjects")
}

model Topic {
  id        String   @id @default(uuid())
  title     String
  position  Int
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([subjectId, position])
  @@map("topics")
}

model MockExam {
  id        String   @id @default(uuid())
  title     String
  createdAt DateTime @default(now())

  performances AreaPerformance[]

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("mock_exams") // Nome da tabela no banco de dados (snake_case)
}

model AreaPerformance {
  id String @id @default(uuid())

  mockExamId String
  mockExam   MockExam @relation(fields: [mockExamId], references: [id], onDelete: Cascade)

  area KnowledgeArea

  correctCount        Int // Acertos
  certaintyCount      Int // Certeza
  doubtCount          Int // Dúvida
  distractionCount    Int // Erro por Distração
  interpretationCount Int // Erro por Interpretação

  @@unique([mockExamId, area])
  @@map("area_performances")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
  SUPER_ADMIN
}

enum KnowledgeArea {
  LANGUAGES // Linguagens
  HUMANITIES // Ciências Humanas
  NATURAL_SCIENCES // Ciências da Natureza
  MATHEMATICS // Matemática
}
